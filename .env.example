# DeepSeek API Key (必需)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 网易云音乐Cookie (可选，但推荐配置以获得更好的音乐体验)
# 获取方法: 浏览器登录网易云音乐，F12开发者工具中复制Cookie
NCM_COOKIE=

# OpenWeather API Key (可选)
# 获取地址: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# 飞书日程服务 (可选)
# 获取地址: https://open.feishu.cn/
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Fish Audio TTS (可选)
# 获取地址: https://fish.audio/
FISH_API_KEY=

# 服务端口
PORT=8080
