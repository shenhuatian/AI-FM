# DeepSeek API Key (从 https://platform.deepseek.com/ 获取)
DEEPSEEK_API_KEY=

# Fish Audio API Key (从 https://fish.audio/ 获取，可选)
FISH_API_KEY=

# 飞书 API (可选，用于读取日程)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# OpenWeather API Key (可选，用于获取天气)
OPENWEATHER_API_KEY=

# 网易云音乐 Cookie (推荐，用于播放VIP歌曲)
# 获取方法：打开 music.163.com，登录后按F12，在Network标签中找到任意请求，复制Cookie
NCM_COOKIE=

# 服务器端口
PORT=8080
