# DeepSeek API Key (从 https://platform.deepseek.com/ 获取)
DEEPSEEK_API_KEY=

# 小米 MiMo API Key (从 https://platform.xiaomimimo.com/ 获取，可选)
# 用于 TTS 语音合成功能
# Token Plan 用户使用 tp- 开头的 key，按量付费用户使用 sk- 开头的 key
XIAOMI_API_KEY=
# Token Plan 用户需要配置 Base URL (按量付费用户不需要)
# 可选值: https://token-plan-cn.xiaomimimo.com, https://token-plan-sgp.xiaomimimo.com, https://token-plan-ams.xiaomimimo.com
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com

# 飞书 API (可选，用于读取日程)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# OpenWeather API Key (可选，用于获取天气)
OPENWEATHER_API_KEY=

# 网易云音乐 Cookie (推荐，用于播放VIP歌曲)
# 获取方法：打开 music.163.com，登录后按F12，在Network标签中找到任意请求，复制Cookie
NCM_COOKIE=

# Spotify API (用于获取音频特征)
# 获取方法：访问 https://developer.spotify.com/dashboard，创建应用后获取
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# 服务器端口
PORT=8080
