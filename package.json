{
  "name": "my-ai-dj",
  "version": "2.0.0",
  "description": "个人AI DJ - 四层架构版本",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "concurrently --kill-others --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,magenta\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "node src/index.js",
    "start:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "import:music": "node scripts/import-music-history.js",
    "test": "node test-config.js"
  },
  "keywords": [
    "ai",
    "dj",
    "music",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "openai": "^4.28.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
