{
  "name": "my-ai-dj",
  "version": "2.0.0",
  "description": "个人AI DJ - 四层架构版本",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "concurrently --names \"NCM-API,BACKEND,FRONTEND\" --prefix-colors \"green,cyan,magenta\" \"npm run start:ncm\" \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "node src/index.js",
    "start:frontend": "cd frontend && npm run dev",
    "start:ncm": "cd netease-api/api-enhanced-main && node server.js",
    "build:frontend": "cd frontend && npm run build",
    "import:music": "node scripts/import-music-history.js",
    "import:chroma": "node scripts/import-to-chroma.js",
    "test": "node test-config.js"
  },
  "keywords": [
    "ai",
    "dj",
    "music",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "@langchain/classic": "^1.0.32",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.44",
    "@langchain/openai": "^1.4.5",
    "chromadb": "^3.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "hnswlib-node": "^3.0.0",
    "https-proxy-agent": "^9.0.0",
    "langchain": "^1.3.5",
    "node-fetch": "^3.3.2",
    "openai": "^4.28.0",
    "spotify-web-api-node": "^5.0.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
